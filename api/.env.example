# ================================
# EJEMPLO DE VARIABLES DE ENTORNO
# ================================
# Copia este archivo a .env y configura tus valores

# === BASE DE DATOS MYSQL ===
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=utmentor

# === JWT ===
JWT_SECRET=tu_clave_secreta_jwt_muy_segura_cambiar_en_produccion

# === STRIPE ===
STRIPE_SECRET_KEY=sk_test_tu_clave_de_stripe

# === EMAIL (Nodemailer) ===
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_contraseña_de_aplicacion

# === MINIO (Almacenamiento) ===
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=utmentor-bucket

# === GENERAL ===
NODE_ENV=development
PORT=3000
